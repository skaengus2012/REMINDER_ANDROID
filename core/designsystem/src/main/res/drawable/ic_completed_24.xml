<!--
  Mirrors checkbox_schedule_check_on_point1 specs:
    - canvas: 24x24dp → viewport 24x24
    - Outer circle: diameter 22dp (r=11), stroke 1.5dp → drawn at r=11-0.75=10.25, centered at 12,12
    - Inner circle: inset 4.5dp from oval edge → inner circle start at 4.5dp from edge → r = 11 - 4.5 - 0.75 = 5.75, centered 12,12
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
      Refined proportions with 2dp padding:
        - Outer R: 10 (24 - 2 - 2 = 20dp diameter)
        - Stroke: 1.4dp (Bold, cute tone)
        - Inner R: 6.8dp (~68% of outer R for better visual presence)
    -->

    <!-- Outer ring: r=10, stroke=1.4dp, centered at (12,12) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FF000000"
        android:strokeWidth="1.4"
        android:pathData="M 12,12 m -10,0 a 10,10 0 1,0 20,0 a 10,10 0 1,0 -20,0" />

    <!-- Inner solid dot: r=6.8, centered at (12,12) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M 12,12 m -6.8,0 a 6.8,6.8 0 1,0 13.6,0 a 6.8,6.8 0 1,0 -13.6,0" />




</vector>
