<!--
  Mirrors checkbox_schedule_check_on_point1 specs:
    - canvas: 24x24dp → viewport 24x24
    - Outer circle: diameter 22dp (r=11), stroke 1.5dp → drawn at r=11-0.75=10.25, centered at 12,12
    - Inner circle: inset 4.5dp from oval edge → inner circle start at 4.5dp from edge → r = 11 - 4.5 - 0.75 = 5.75, centered 12,12
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
      Scaled down from checkbox_schedule_check_on_point1 to match the visual size
      of other icons (adding ~3dp padding):
        - Original Outer R: 11  -> New Outer R: 9
        - Original Stroke: 1.5 -> New Stroke: 1.2
        - Original Inner R: 7.5 -> New Inner R: 6.1
    -->

    <!-- Outer ring: r=9, stroke=1.2dp, centered at (12,12) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FF000000"
        android:strokeWidth="1.2"
        android:pathData="M 12,12 m -9,0 a 9,9 0 1,0 18,0 a 9,9 0 1,0 -18,0" />

    <!-- Inner solid dot: r=6.1, centered at (12,12) -->
    <path
        android:fillColor="#FF000000"
        android:pathData="M 12,12 m -6.1,0 a 6.1,6.1 0 1,0 12.2,0 a 6.1,6.1 0 1,0 -12.2,0" />



</vector>
